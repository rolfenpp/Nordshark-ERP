# Copy to ".env" and adjust. Vite reads VITE_* at build/dev startup only.

# Base URL must include the /api segment (controllers are under api/*).
# Local: dotnet run from ERP-api → default http://localhost:8080/api
# Docker / compose may use http://localhost:5000/api — set accordingly.
VITE_API_BASE_URL=http://localhost:8080/api

# Optional: Gemini for the in-app AI assistant
# VITE_GEMINI_API_KEY=
