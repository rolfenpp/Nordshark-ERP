# Copy to ".env" and adjust. Vite reads VITE_* at build/dev startup only.

# Local API (dotnet run from ERP-api → http://localhost:8080)
# Docker ERP-api publish is often http://localhost:5000 — set that here if you use compose web.
VITE_API_BASE_URL=http://localhost:8080

# Optional: Gemini for the in-app AI assistant
# VITE_GEMINI_API_KEY=
