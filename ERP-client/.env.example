# Copy this to `.env` and adjust — Vite only looks at VITE_* when you start dev or build.

# Has to include `/api` (controllers live under that).
# dotnet run from ERP-api → defaults to http://localhost:8080/api usually
# docker / compose sometimes uses a diff port eg 5000, change if thats you.
VITE_API_BASE_URL=http://localhost:8080/api

# Gemini api key only if youre using the in-app ai assistant. Ignore otherwise.
# VITE_GEMINI_API_KEY=

